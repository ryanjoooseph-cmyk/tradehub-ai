[
  {
    "feature": "schema_jobs",
    "entity": "jobs",
    "spec": {
      "columns": {
        "id": "uuid primary key default gen_random_uuid()",
        "title": "text not null",
        "description": "text not null",
        "budget": "numeric(12,2) not null",
        "currency": "text not null default 'AUD'",
        "customer_id": "uuid not null",
        "tradie_id": "uuid",
        "status": "text not null default 'open'",
        "location": "text",
        "created_at": "timestamp with time zone not null default now()",
        "updated_at": "timestamp with time zone not null default now()"
      },
      "indexes": ["(customer_id)", "(tradie_id)", "(status)"],
      "fkeys": {
        "customer_id": "references auth.users(id)",
        "tradie_id": "references auth.users(id)"
      }
    },
    "acceptance": [
      "Idempotent SQL: CREATE TABLE IF NOT EXISTS and ALTERs",
      "Add sensible indexes and foreign keys",
      "SQL saved to migrations or sql/ folder"
    ]
  },

  {
    "feature": "api_jobs",
    "entity": "jobs",
    "spec": {
      "routes": ["GET /api/jobs", "POST /api/jobs", "GET /api/jobs/:id", "PATCH /api/jobs/:id"],
      "auth": "RLS-friendly; only owner or assigned tradie can PATCH",
      "validation": "Zod schemas for input/output"
    },
    "acceptance": [
      "Next.js 14 Route Handlers at app/api/jobs/route.ts",
      "TypeScript, Zod, proper error handling",
      "Uses Supabase client (server) for DB calls"
    ]
  },

  {
    "feature": "page_jobs",
    "entity": "jobs",
    "spec": {
      "pages": [
        "app/jobs/new/page.tsx (form: title, description, budget, currency, location)",
        "app/jobs/page.tsx (list with server-side fetch of recent jobs)"
      ],
      "ui": "React Hook Form + Zod; posts to /api/jobs"
    },
    "acceptance": [
      "Pages render without placeholders",
      "Form validates and creates a job via API",
      "Basic styling with your existing app styles"
    ]
  },

  {
    "feature": "schema_invoices",
